# ╔══════════════════════════════════════════╗
# ║   YTTA Community Bot — Environment Vars  ║
# ╚══════════════════════════════════════════╝

# Token bot kamu (dari Discord Developer Portal)
# Cara dapat: https://discord.com/developers/applications → Bot → Token
BOT_TOKEN=masukkan_token_bot_kamu_disini

# Client ID / Application ID bot kamu
# Cara dapat: Discord Developer Portal → General Information → Application ID
CLIENT_ID=masukkan_client_id_kamu_disini

# Port untuk keep-alive server (Railway otomatis set ini, tidak perlu diubah)
PORT=3000
